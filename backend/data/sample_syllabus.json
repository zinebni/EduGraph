{
  "program_name": "Bachelor in Computer Science - Web Development Track",
  "institution": "University of Technology",
  "target_audience": "3rd year CS students",
  "total_hours": 120,
  "modules": [
    {
      "module_id": "WD101",
      "title": "Introduction to Web Development",
      "hours": 20,
      "topics": ["HTML basics", "CSS fundamentals", "JavaScript intro", "DOM manipulation"],
      "prerequisites": []
    },
    {
      "module_id": "WD102",
      "title": "Backend Development",
      "hours": 25,
      "topics": ["PHP basics", "MySQL databases", "Server-side rendering", "MVC pattern"],
      "prerequisites": ["WD101"]
    },
    {
      "module_id": "WD103",
      "title": "Frontend Frameworks",
      "hours": 25,
      "topics": ["jQuery", "Bootstrap", "AJAX", "Responsive design"],
      "prerequisites": ["WD101"]
    },
    {
      "module_id": "WD104",
      "title": "Database Management",
      "hours": 20,
      "topics": ["SQL queries", "Database design", "Normalization", "Stored procedures"],
      "prerequisites": ["WD102"]
    },
    {
      "module_id": "WD105",
      "title": "Web Security",
      "hours": 15,
      "topics": ["XSS prevention", "SQL injection", "Authentication", "HTTPS"],
      "prerequisites": ["WD102", "WD104"]
    },
    {
      "module_id": "WD106",
      "title": "Final Project",
      "hours": 15,
      "topics": ["Project planning", "Full-stack application", "Deployment", "Presentation"],
      "prerequisites": ["WD101", "WD102", "WD103", "WD104", "WD105"]
    }
  ]
}
